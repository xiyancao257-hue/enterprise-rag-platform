# Copy this file to `.env` for local production-style Docker runs.
# Do not commit real secrets.

# FastAPI auth. Use a long random value for real deployments.
ENTERPRISE_RAG_API_KEY=replace-with-real-api-key
ENTERPRISE_RAG_API_KEYS=replace-with-real-api-key

# Runtime config used by docker-compose.prod.yml.
ENTERPRISE_RAG_CONFIG=config/production.example.json

# Optional OpenAI provider integration.
# Keep production.example.json on stub/hashing for deterministic local demos,
# or switch llm.provider / embedding.provider to "openai" and set this key.
OPENAI_API_KEY=

# Optional OCR cloud provider secrets.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AWS_REGION=

# Local service URLs used by Docker Compose.
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0
