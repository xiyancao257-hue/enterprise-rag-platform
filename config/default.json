{
  "retrieval": {
    "top_k": 5,
    "enable_graph": false,
    "graph_max_hops": 2,
    "experiment_k_values": [1, 3, 5, 8]
  },
  "security": {
    "default_user_groups": []
  },
  "api_security": {
    "require_api_key": false,
    "api_key_env_var": "ENTERPRISE_RAG_API_KEYS",
    "api_key_hashes": [],
    "api_keys": [],
    "rate_limit_requests": 60,
    "rate_limit_window_seconds": 60
  },
  "vector_index": {
    "provider": "memory",
    "collection_name": "enterprise_rag_chunks",
    "url": "http://localhost:6333"
  },
  "jobs": {
    "running_timeout_seconds": 1800,
    "worker_poll_seconds": 5.0
  },
  "ingestion": {
    "allowed_source_roots": [],
    "allowed_extensions": [".txt", ".md"],
    "max_file_bytes": 10000000
  },
  "llm": {
    "provider": "stub",
    "model": "gpt-4.1-mini",
    "input_cost_per_1k_tokens": 0.0,
    "output_cost_per_1k_tokens": 0.0
  },
  "guardrails": {
    "min_citations": 1,
    "min_top_score": 0.01,
    "min_evidence_tokens": 5,
    "max_estimated_cost_usd": 0.0,
    "max_latency_ms": 0.0,
    "sensitive_terms": ["legal", "medical", "finance", "security", "compliance"]
  },
  "audit": {
    "enabled": false,
    "path": "data/audit/audit.jsonl"
  },
  "leases": {
    "provider": "memory",
    "url": "redis://redis:6379/0",
    "prefix": "enterprise-rag"
  },
  "cache": {
    "provider": "memory",
    "url": "redis://redis:6379/0",
    "prefix": "enterprise-rag",
    "query_ttl_seconds": 300,
    "embedding_ttl_seconds": 86400
  }
}
